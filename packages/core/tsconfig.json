{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@/lib/*": ["./lib/*"],
      "@/config/*": ["./config/*"],
      "@fortuneteller/saju": ["../saju/src/index.ts"],
      "@fortuneteller/saju/*": ["../saju/src/*.ts"]
    }
  },
  "include": ["lib/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules"]
}
