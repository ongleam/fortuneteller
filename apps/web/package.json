{
  "name": "@fortuneteller/web",
  "version": "3.0.8",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo 2>&1 | tee logs/server.log",
    "build": "next build",
    "vercel-build": "if [ \"$VERCEL_ENV\" = \"production\" ]; then tsx ../../packages/db/migrate.ts; fi && next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "ci": "bun run format:check && bun run typecheck && bun run test && bun run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx ../../packages/db/migrate.ts",
    "db:studio": "NODE_TLS_REJECT_UNAUTHORIZED=0  drizzle-kit studio",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "db:pull": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit pull",
    "db:check": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit check",
    "db:up": "drizzle-kit up",
    "test": "bun test tests",
    "test:playwright": "export PLAYWRIGHT=True && pnpm exec playwright test"
  },
  "dependencies": {
    "@fortuneteller/modules": "workspace:*",
    "@fortuneteller/shared": "workspace:*",
    "@fortuneteller/config": "workspace:*",
    "@fortuneteller/db": "workspace:*",
    "@fortuneteller/clients": "workspace:*",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/react": "^3.0.210",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@supabase/auth-js": "^2.69.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "ai": "6.0.208",
    "axios": "^1.9.0",
    "bcrypt-ts": "^5.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^11.3.19",
    "geist": "^1.3.1",
    "import-in-the-middle": "^1.14.0",
    "lucide-react": "^0.446.0",
    "nanoid": "^5.0.8",
    "next": "15.5.19",
    "next-themes": "^0.3.0",
    "orderedmap": "^2.1.1",
    "postgres": "^3.4.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "require-in-the-middle": "^7.5.2",
    "server-only": "^0.0.1",
    "sonner": "^1.5.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/d3-scale": "^4.0.8",
    "@types/node": "^22.8.6",
    "@types/papaparse": "^5.3.15",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "msw": "^2.8.4",
    "postcss": "^8.5.15",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "packageManager": "bun@1.3.8"
}
