{
  "name": "fortuneteller-monorepo",
  "version": "3.0.8",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '@fortuneteller/web' dev",
    "build": "bun --filter '@fortuneteller/web' build",
    "start": "bun --filter '@fortuneteller/web' start",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '@fortuneteller/web' test",
    "test:arch": "bun test tests/architecture",
    "test:playwright": "bun --filter '@fortuneteller/web' test:playwright",
    "db:generate": "bun --filter '@fortuneteller/web' db:generate",
    "db:migrate": "bun --filter '@fortuneteller/web' db:migrate",
    "db:studio": "bun --filter '@fortuneteller/web' db:studio",
    "db:push": "bun --filter '@fortuneteller/web' db:push",
    "db:pull": "bun --filter '@fortuneteller/web' db:pull",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "packageManager": "bun@1.3.8"
}
