{
  "name": "ai-chatbot",
  "version": "3.0.8",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo 2>&1 | tee logs/debug.txt",
    "build": "tsx lib/infra/db/migrate && next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/infra/db/migrate.ts",
    "db:studio": "NODE_TLS_REJECT_UNAUTHORIZED=0  drizzle-kit studio",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "db:pull": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit pull",
    "db:check": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit check",
    "db:up": "drizzle-kit up",
    "test": "jest",
    "test:core": "jest tests/core",
    "test:infra": "jest tests/infra",
    "test:interfaces": "jest tests/interfaces",
    "test:shared": "jest tests/shared",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:playwright": "export PLAYWRIGHT=True && pnpm exec playwright test",
    "test:promptfoo": "npx tsx ./tests/promptfoo/generate_config.ts && GOOGLE_APPLICATION_CREDENTIALS=./google_auth_key.json npx promptfoo eval --no-cache -c ./tests/promptfoo/generated_config.yaml -j 20",
    "test:promptfoo:view": "npx promptfoo view -y",
    "test:promptfoo:save": "tsx ./tests/promptfoo/parse_notion.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.18",
    "@ai-sdk/google-vertex": "^2.2.18",
    "@ai-sdk/react": "^1.2.8",
    "@next/third-parties": "^15.3.2",
    "@notionhq/client": "^3.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@slack/web-api": "^7.9.1",
    "@supabase/auth-js": "^2.69.1",
    "@supabase/ssr": "^0.6.1",
