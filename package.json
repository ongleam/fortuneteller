    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.34.0",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^11.3.19",
    "geist": "^1.3.1",
    "import-in-the-middle": "^1.14.0",
    "lucide-react": "^0.446.0",
